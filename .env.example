# ============================================================
# KulPik Environment Variables Template
# ============================================================
# This file contains all required and optional environment variables.
# Copy this to .env.local (development) or .env.production (production)
# and fill in your actual API keys and configuration values.
# ============================================================

# ----------------------------------------------------
# Supabase Configuration (REQUIRED)
# Get these from: https://app.supabase.com/project/_/settings/api
# ----------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ----------------------------------------------------
# AI API Keys (REQUIRED for Auto-Curation Features)
# ----------------------------------------------------
# EXA API: https://exa.ai/ - For searching laptop information
EXA_API_KEY=your-exa-api-key-here

# Cohere API: https://cohere.com/ - For embeddings and text processing
COHERE_API_KEY=your-cohere-api-key-here

# Optional: Google Gemini API (Enhanced recommendations)
GEMINI_API_KEY=your-gemini-api-key-here

# ----------------------------------------------------
# Application Configuration
# ----------------------------------------------------
# Frontend application URL
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Backend server port (default: 5000)
PORT=5000

# Debug mode: Set 'true' for development, 'false' for production
DEBUG=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ----------------------------------------------------
# Development Only (Optional)
# ----------------------------------------------------
# Database connection string for local PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/kulpik

# Mailchimp/API keys for newsletters (if using)
MAILCHIMP_API_KEY=

# Affiliate tracking IDs (for monetization)
TOKOPEDIA_AFFILIATE_ID=
SHOPEE_AFFILIATE_ID=

